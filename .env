- name: Create .env file
  run: |
    echo "SUPABASE_URL=${{ secrets.SUPABASE_URL }}" >> .env
    echo "SUPABASE_SERVICE_ROLE_KEY=${{ secrets.SUPABASE_SERVICE_ROLE_KEY }}" >> .env
    echo "SUPABASE_URL2=${{ secrets.SUPABASE_URL2 }}" >> .env
    echo "SUPABASE_SERVICE_ROLE_KEY2=${{ secrets.SUPABASE_SERVICE_ROLE_KEY2 }}" >> .env
    echo "TMDB_API_KEY=${{ secrets.TMDB_API_KEY }}" >> .env
    echo "TVDB_API_KEY=${{ secrets.TVDB_API_KEY }}" >> .env

- name: Run sync server
  run: node sync-server.js
